# Optional. Leave empty to use same-origin requests (recommended behind reverse proxy).
VITE_API_BASE_URL=

# Dev-only convenience override for Vite's /api proxy target.
# Example: http://localhost:3000
VITE_DEV_API_TARGET=

# Login bypass toggle used by the Auth screen.
# In production builds, bypass stays hidden unless your code condition changes.
# For local/dev, set to false to hide the button.
VITE_ENABLE_LOGIN_BYPASS=true

# Optional token used when bypass button is clicked.
# Leave as-is for local testing, or replace with a test token.
VITE_BYPASS_ACCESS_TOKEN=dev-login-bypass
